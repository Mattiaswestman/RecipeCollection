<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeCollection.Views.RecipePage"
			 Title="Recipe Page"
			 xmlns:viewmodel="clr-namespace:RecipeCollection.ViewModels"
			 x:DataType="viewmodel:RecipePageViewModel">

	<Grid RowSpacing="30"
		  Padding="25">
		<Grid.RowDefinitions>
			<RowDefinition Height="0.25*" />
			<RowDefinition Height="0.75*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0.25*" />
				<ColumnDefinition Width="0.5*" />
				<ColumnDefinition Width="0.25*" />
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0"
					Command="{Binding TapReturnCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Back"
					FontSize="24"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}">
			</Button>

			<Label Grid.Column="1"
				   HorizontalOptions="Center"
				   VerticalOptions="Center"
				   Text="{Binding RecipeTitle}"
				   FontSize="30"
				   FontAttributes="Bold"
				   TextColor="{StaticResource Orange}" />
		</Grid>

		<Grid Grid.Row="1"
			  ColumnSpacing="30">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0.25*" />
				<ColumnDefinition Width="0.75*" />
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0"
					HorizontalOptions="Fill"
					VerticalOptions="Fill"
					Padding="10, 10"
					StrokeThickness="1">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="10" />
				</Border.StrokeShape>

				<Label HorizontalOptions="Start"
					   VerticalOptions="Start"
					   Text="{Binding IngredientsText}"
					   FontSize="24"
					   FontAttributes="Bold"
					   TextColor="{StaticResource Gray600}" />
			</Border>

			<Border Grid.Column="1"
					HorizontalOptions="Fill"
					VerticalOptions="Fill"
					Padding="10, 10"
					StrokeThickness="1">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="10" />
				</Border.StrokeShape>

				<Label HorizontalOptions="Start"
					   VerticalOptions="Start"
					   Text="{Binding InstructionsText}"
					   FontSize="24"
					   FontAttributes="Bold"
					   TextColor="{StaticResource Gray600}" />
			</Border>
		</Grid>
	</Grid>
</ContentPage>